library(survival)
library(survminer)
install.packages("survival")
install.packages("survminer")
install.packages("survival")
install.packages("survminer")
library(survival)
library(survminer)
str(lung)
# ubah status jadi 0 (censored), 1 (event)
lung$status <- ifelse(lung$status == 2, 1, 0)
# ubah sex jadi label
lung$sex <- factor(lung$sex, levels = c(1, 2), labels = c("Pria", "Wanita"))
# membuat objek survival
surv_obj <- Surv(time = lung$time, event = lung$status)
# estimasi KM berdasarkan JK
km_sex <- survfit(surv_obj ~ sex, data = lung)
summary(km_sex)
# plot
ggsurvplot(km_sex, data = lung,
pval = TRUE,
conf.int = TRUE,
risk.table = TRUE,
surv.median.line = "hv",
legend.labs = c("Pria", "Wanitas"),
palette = c("#E78800", "#2E9FDF"))
# plot
ggsurvplot(km_sex, data = lung,
pval = TRUE,
conf.int = TRUE,
risk.table = TRUE,
surv.median.line = "hv",
legend.labs = c("Pria", "Wanita"),
palette = c("#E78800", "#2E9FDF"))
