R2 <- 1 - sum((test_data$medv - prediksi)^2) / sum((test_data$medv - mean(test_data$medv))^2)
cat("\n", "MSE : ", MSE, "\n",
"RMSE : ", RMSE, "\n",
"R_Squared:", R2, "\n"
)
importance(model_rf)
varImpPlot(model_rf, main = "Veriabel Yang Penting dalam Membentuk Model")
varImpPlot(model_rf, main = "Veriabel Yang Penting dalam Membentuk Model")
varImpPlot(model_rf, main = "Variabel Yang Penting dalam Membentuk Model" )
varImpPlot(model_rf, main = "Variabel Yang Penting dalam Membentuk Model" )
