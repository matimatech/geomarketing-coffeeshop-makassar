library(MASS)
library(tidyverse)
library(randomForest)
#tentang data
data("Boston")
?Boston
#informasi data
head(Boston)
glimpse(Boston)
summary(Boston)
Boston |>
ggplot(aes(x = medv))+
geom_histogram(binwidth = 1)+
labs(title = "distribusi harga rumah di boston",
x = "harga rumah",
y = "frekuensi")
Boston |>
ggplot(aes(x = medv))+
geom_histogram(binwidth = 1)+
facet_wrap(~chas, nrow = 2)+
labs(title = "distribusi harga rumah berdasarkan lokasi sungai",
x = "harga rumah",
y = "frekuensi")
Boston |>
ggplot(aes(x = medv, y = medv))+
geom_point(binwidth = 0.6)+
labs(title = "jumlah rumah vs warga",
x = "harga rumah",
y = "kamar")
#machine learning random forest
set.seed(123)
sampel <- sample(1:nrow(Boston), 0.7*nrow(Boston))
train_data <- Boston[sampel,]
test_data <- Boston[-sampel,]
model_rf <- randomForest(medv ~ . , data = train_data,
ntree = 500, mtry = 4,
importance = T)
print(model_rf)
#prediksi
prediksi <- predict(model_rf, newdata = test_data)
head(prediksi)
MSE <- mean((test_data$medv - prediksi)^2)
RMSE <- sqrt(MSE)
R2 <- 1 - sum((test_data$medv - prediksi)^2) / sum((test_data$medv - mean(test_data))^2)
cat("\n", "MSE :", MSE, "\n",
"RMSE :", RMSE, "\n",
"R_Squared :", R2, "\n")
importance(model_rf)
varImpPlot(model_rf, main = "variabel yang penting membentuk model")
